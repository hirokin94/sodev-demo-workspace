From 3f70d25a18a0a4f659df8237b6afbe5e6467606d Mon Sep 17 00:00:00 2001
From: Hiroyuki Ishii <ishii.hiroyuki002@jp.panasonic.com>
Date: Mon, 16 Feb 2026 10:35:19 +0900
Subject: [PATCH] flutter-cluster: Add standalone dummy signal mode

Introduced a dummy signal mode that operates independently
within the flutter-cluster app. This is necessary because
vcan is not enabled in the guest domain at the moment, making it
impossible to use simple_can_simulator.py.

Change-Id: Ic725c1dafcc69c0882d23ad32b63b6dadc66f0d8
Signed-off-by: Hiroyuki Ishii <ishii.hiroyuki002@jp.panasonic.com>
---
 .../files/0001-Implement-dummy-signal.patch   | 114 ++++++++++++++++++
 .../flutter-cluster-dashboard_git.bb          |   7 ++
 2 files changed, 121 insertions(+)
 create mode 100644 recipes-demo/flutter-cluster-dashboard/files/0001-Implement-dummy-signal.patch

diff --git a/recipes-demo/flutter-cluster-dashboard/files/0001-Implement-dummy-signal.patch b/recipes-demo/flutter-cluster-dashboard/files/0001-Implement-dummy-signal.patch
new file mode 100644
index 0000000..594abd4
--- /dev/null
+++ b/recipes-demo/flutter-cluster-dashboard/files/0001-Implement-dummy-signal.patch
@@ -0,0 +1,114 @@
+From 20c64cdaa64652aabda82e82061f01b680f57782 Mon Sep 17 00:00:00 2001
+From: Hiroyuki Ishii <ishii.hiroyuki002@jp.panasonic.com>
+Date: Mon, 16 Feb 2026 10:30:59 +0900
+Subject: [PATCH] Implement dummy signal
+
+Signed-off-by: Hiroyuki Ishii <ishii.hiroyuki002@jp.panasonic.com>
+---
+ lib/screen/home.dart                          | 21 ++++++--
+ .../dummy_signal_generator.dart               | 52 +++++++++++++++++++
+ 2 files changed, 69 insertions(+), 4 deletions(-)
+ create mode 100644 lib/vehicle-signals/dummy_signal_generator.dart
+
+diff --git a/lib/screen/home.dart b/lib/screen/home.dart
+index d9bfa32..7b92897 100644
+--- a/lib/screen/home.dart
++++ b/lib/screen/home.dart
+@@ -16,6 +16,7 @@ import 'package:flutter_cluster_dashboard/screen/widgets/turn_signal.dart';
+ import 'package:flutter_cluster_dashboard/vehicle-signals/vss_client.dart';
+ import 'package:flutter_cluster_dashboard/vehicle-signals/vss_provider.dart';
+ import 'package:flutter_cluster_dashboard/vehicle-signals/vehicle_status_provider.dart';
++import 'package:flutter_cluster_dashboard/vehicle-signals/dummy_signal_generator.dart';
+ import 'package:intl/intl.dart';
+ 
+ class Home extends ConsumerStatefulWidget {
+@@ -27,12 +28,24 @@ class Home extends ConsumerStatefulWidget {
+ 
+ class _HomeState extends ConsumerState<Home> {
+   late VssClient vss;
++  DummySignalGenerator? dummyGen;
+ 
+-  initState() {
+-    vss = ref.read(vssClientProvider);
+-    vss.run();
+-
++  @override
++  void initState() {
+     super.initState();
++    _setupSignalSource();
++  }
++
++  Future<void> _setupSignalSource() async {
++    final notifier = ref.read(vehicleStatusProvider.notifier);
++    final dummyEnabled = await isDummySignalEnabled();
++    if (dummyEnabled) {
++      dummyGen = DummySignalGenerator(notifier);
++      dummyGen!.start();
++    } else {
++      vss = ref.read(vssClientProvider);
++      vss.run();
++    }
+   }
+ 
+   GaugeColors? getGaugeColor(String mode) {
+diff --git a/lib/vehicle-signals/dummy_signal_generator.dart b/lib/vehicle-signals/dummy_signal_generator.dart
+new file mode 100644
+index 0000000..aab1794
+--- /dev/null
++++ b/lib/vehicle-signals/dummy_signal_generator.dart
+@@ -0,0 +1,52 @@
++import 'dart:async';
++import 'dart:math';
++import 'package:flutter_riverpod/flutter_riverpod.dart';
++import 'vehicle_status_provider.dart';
++import 'dart:io';
++/// Checks if the dummy signal file exists
++Future<bool> isDummySignalEnabled() async {
++  final file = File('/etc/xdg/AGL/cluster-dashboard/enable-dummy-signal');
++  return await file.exists();
++}
++
++/// Dummy signal generator for vehicle status
++class DummySignalGenerator {
++  final VehicleStatusNotifier notifier;
++  Timer? _timer;
++  double _speed = 0;
++  int _rpm = 600;
++  bool _increasing = true;
++  final Random _random = Random();
++
++  DummySignalGenerator(this.notifier);
++
++  void start() {
++    _timer = Timer.periodic(Duration(milliseconds: 100), (_) => _update());
++  }
++
++  void stop() {
++    _timer?.cancel();
++  }
++
++  void _update() {
++    // Simulate speed and rpm changes
++    if (_increasing) {
++      _speed += _random.nextDouble() * 2;
++      _rpm += _random.nextInt(50);
++      if (_speed > 100) _increasing = false;
++    } else {
++      _speed -= _random.nextDouble() * 2;
++      _rpm -= _random.nextInt(50);
++      if (_speed < 10) _increasing = true;
++    }
++    if (_rpm < 600) _rpm = 600;
++    if (_rpm > 4000) _rpm = 4000;
++    if (_speed < 0) _speed = 0;
++    if (_speed > 140) _speed = 140;
++    notifier.update(
++      speed: _speed,
++      rpm: _rpm,
++      selectedGear: 'D',
++    );
++  }
++}
+-- 
+2.34.1
+
diff --git a/recipes-demo/flutter-cluster-dashboard/flutter-cluster-dashboard_git.bb b/recipes-demo/flutter-cluster-dashboard/flutter-cluster-dashboard_git.bb
index 15fce6b..2f0e2b8 100644
--- a/recipes-demo/flutter-cluster-dashboard/flutter-cluster-dashboard_git.bb
+++ b/recipes-demo/flutter-cluster-dashboard/flutter-cluster-dashboard_git.bb
@@ -18,6 +18,7 @@ SRC_URI = "git://gerrit.automotivelinux.org/gerrit/apps/flutter-instrument-clust
     file://cluster-dashboard.yaml.kvm-demo-preconfigured \
     file://cluster-dashboard.token \
     file://kvm.conf \
+    file://0001-Implement-dummy-signal.patch \
 "
 
 PV = "1.0+git${SRCPV}"
@@ -35,6 +36,8 @@ PUBSPEC_IGNORE_LOCKFILE = "1"
 
 SYSTEMD_SERVICE:${PN} = "flutter-cluster-dashboard.service"
 
+ENABLE_STANDALONE_DUMMY_SIGNAL = "1"
+
 do_install:append() {
     install -D -m 0644 ${WORKDIR}/${BPN}.service ${D}${systemd_system_unitdir}/${BPN}.service
 
@@ -47,6 +50,10 @@ do_install:append() {
     install -m 0644 ${WORKDIR}/cluster-dashboard.yaml.kvm-demo ${D}${sysconfdir}/xdg/AGL/
     install -m 0644 ${WORKDIR}/cluster-dashboard.yaml.kvm-demo-preconfigured ${D}${sysconfdir}/xdg/AGL/
     install -m 0644 ${WORKDIR}/cluster-dashboard.token ${D}${sysconfdir}/xdg/AGL/cluster-dashboard/
+
+    if [ "${ENABLE_STANDALONE_DUMMY_SIGNAL}" = "1" ]; then
+        touch ${D}${sysconfdir}/xdg/AGL/cluster-dashboard/enable-dummy-signal
+    fi
 }
 
 ALTERNATIVE_LINK_NAME[cluster-dashboard.yaml] = "${sysconfdir}/xdg/AGL/cluster-dashboard.yaml"
-- 
